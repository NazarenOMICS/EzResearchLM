# EZresearchLM configuration

# Optional. Defaults to the repository root.
EZRESEARCH_ROOT=
EZRESEARCH_VAULT=
EZRESEARCH_PYTHON=

# NotebookLM browser auth storage. Leave empty to use the default user profile.
NOTEBOOKLM_STORAGE_STATE=

# Optional scholarly API helpers.
PAPER_SEARCH_MCP_UNPAYWALL_EMAIL=
NCBI_EMAIL=
NCBI_API_KEY=

# Optional browser override for Anna fallback if Playwright cannot find Chromium.
PAPER_SEARCH_MCP_PLAYWRIGHT_CHROMIUM=

# Optional model provider keys for local helper scripts.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
